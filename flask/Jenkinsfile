 pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Downloads your code from the specific repository
                git branch: 'main',
                    url: 'https://github.com/arunkumarmniloor-eng/k8s-Flask-Express-app.git'
        }
        }
                      stage('Install Dependencies') {
            steps {
                sh '''
                    cd flask
                    # Re-create venv to ensure it's fresh
                    rm -rf venv
                    python3 -m venv venv
                    
                    # Call pip THROUGH the python executable (bypasses permission issues)
                    ./venv/bin/python3 -m pip install --upgrade pip
                    ./venv/bin/python3 -m pip install -r requirements.txt
                '''
            }
        }



        stage('Test') {
            steps {
                sh '''
                    cd flask
                    # Use the python executable inside the venv to run tests
                    ./venv/bin/python3 -m pytest tests/ --tb=short || true
                '''
            }
        }

                stage('Deploy') {
            steps {
                sh '''
                    cd flask
                    # Tell PM2 to use the python interpreter from the venv
                    sudo pm2 restart flask-app || sudo pm2 start app.py --name flask-app --interpreter ./venv/bin/python3
                '''
            }
        }

    }

    post {  
        success {
            echo 'Flask deployment successful!'
        }
        failure {
            echo 'Flask deployment failed!'
        }
    }
}






  
