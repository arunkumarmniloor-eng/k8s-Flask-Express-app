pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/arunkumarmniloor-eng/k8s-Flask-Express-app.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    # Create venv if it doesn't exist, then use '.' instead of 'source'
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    # Run tests inside the workspace using the local venv
                    . venv/bin/activate
                    python3 -m pytest tests/ --tb=short || true
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    # Instead of cd-ing to /home/ubuntu, stay in the workspace 
                    # Use pm2 to start the app from the current location
                    sudo pm2 restart flask-app || sudo pm2 start app.py --name flask-app
                '''
            }
        }
    }

    post {
        success {
            echo 'Flask deployment successful!'
        }
        failure {
            echo 'Flask deployment failed!'
        }
    }
}
