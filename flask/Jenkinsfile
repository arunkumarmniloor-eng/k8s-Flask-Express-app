 pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Downloads your code from the specific repository
                git branch: 'main',
                    url: 'https://github.com/arunkumarmniloor-eng/k8s-Flask-Express-app.git'
        }
        }
               stage('Install Dependencies') {
            steps {
                sh '''
                    cd flask
                    python3 -m venv venv
                    
                    # Grant execution permissions to the venv bin folder
                    chmod -R +x venv/bin/
                    
                    ./venv/bin/pip install --upgrade pip
                    ./venv/bin/pip install -r requirements.txt
                '''
            }
        }


        stage('Test') {
            steps {
                sh '''
                    cd flask
                    # Use the python executable inside the venv to run tests
                    ./venv/bin/python3 -m pytest tests/ --tb=short || true
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    cd flask
                    # Restarts the app if it's already running, or starts it if it's new
                    # Note: This requires 'sudo' permissions for the jenkins user
                    sudo pm2 restart flask-app || sudo pm2 start app.py --name flask-app
                '''
            }
        }
    }

    post {  
        success {
            echo 'Flask deployment successful!'
        }
        failure {
            echo 'Flask deployment failed!'
        }
    }
}






  
